{
  "name": "hashi-bot2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm --filter @hashi/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter @hashi/web lint",
    "worker": "pnpm --filter @hashi/worker dev",
    "prisma:generate": "pnpm --filter @hashi/db prisma:generate",
    "prisma:migrate": "pnpm --filter @hashi/db prisma:migrate",
    "backtest": "tsx scripts/run-backtest.ts",
    "validate:signal-output": "tsx scripts/validate-signal-mode-output.ts",
    "validate:phase-b6": "HASHI_ENV_FILE=.env.signal tsx scripts/validate-phase-b6-local-run-ready.ts",
    "validate:env": "bash scripts/validate-env.sh .env.production",
    "validate:signal-prod": "bash scripts/validate-signal-prod.sh",
    "validate:prop-prod": "pnpm validate:env && tsx scripts/validate-demo-connectors.ts",
    "validate:telegram": "curl -s -X POST http://localhost:3000/api/telegram/test || true",
    "validate:ui-contract": "tsx scripts/validate-ui-contract.ts",
    "validate:paper-execution": "tsx scripts/validate-paper-execution.ts",
    "validate:responsive-ui": "tsx scripts/validate-responsive-ui.ts",
    "db:generate": "pnpm prisma:generate",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "signal:truth-check": "tsx scripts/signal-truth-check.ts",
    "signal:lifecycle-smoke": "tsx scripts/signal-lifecycle-smoke.ts",
    "local:verify": "HASHI_ENV_FILE=.env.signal tsx scripts/local-verify.ts",
    "signal:e2e": "HASHI_ENV_FILE=.env.signal tsx scripts/signal-e2e.ts",
    "runtime:stability": "tsx scripts/signal-lifecycle-smoke.ts",
    "contabo:readiness": "HASHI_ENV_FILE=.env.signal tsx scripts/contabo-readiness.ts",
    "local:verify:docker": "docker compose exec -T worker pnpm run local:verify",
    "signal:e2e:docker": "docker compose exec -T worker pnpm run signal:e2e",
    "contabo:readiness:docker": "docker compose exec -T worker pnpm run contabo:readiness",
    "runtime:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/runtime-prove.ts",
    "telegram:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/telegram-prove.ts",
    "ui:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/ui-prove.ts",
    "strategy:readiness": "HASHI_ENV_FILE=.env.signal tsx scripts/strategy-readiness.ts",
    "personal:readiness": "tsx scripts/personal-readiness.ts",
    "prop:readiness": "tsx scripts/prop-readiness.ts",
    "partitions:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/partitions-prove.ts",
    "merge:readiness": "HASHI_ENV_FILE=.env.signal tsx scripts/merge-readiness.ts",
    "modes:readiness": "HASHI_ENV_FILE=.env.signal tsx scripts/modes-readiness.ts",
    "phase16:buildout": "pnpm run typecheck",
    "worker:runtime:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/worker-runtime-prove.ts",
    "tracker:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/tracker-prove.ts",
    "telegram:lifecycle:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/telegram-lifecycle-prove.ts",
    "signal:paper:prove": "HASHI_ENV_FILE=.env.signal tsx scripts/signal-paper-prove.ts",
    "local:start": "bash scripts/local-start.sh",
    "local:reset": "bash scripts/local-reset.sh",
    "local:logs": "bash scripts/local-logs.sh",
    "local:health": "tsx scripts/local-health.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.20.6",
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
