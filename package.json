{
  "name": "hashi-bot2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm --filter @hashi/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter @hashi/web lint",
    "worker": "pnpm --filter @hashi/worker dev",
    "prisma:generate": "pnpm --filter @hashi/db prisma:generate",
    "prisma:migrate": "pnpm --filter @hashi/db prisma:migrate",
    "backtest": "tsx scripts/run-backtest.ts",
    "validate:signal-output": "tsx scripts/validate-signal-mode-output.ts",
    "validate:phase-b6": "HASHI_ENV_FILE=.env.signal tsx scripts/validate-phase-b6-local-run-ready.ts",
    "validate:env": "bash scripts/validate-env.sh .env.production",
    "validate:signal-prod": "pnpm validate:env && tsx scripts/validate-signal-prod.ts",
    "validate:prop-prod": "pnpm validate:env && tsx scripts/validate-demo-connectors.ts",
    "validate:telegram": "curl -s -X POST http://localhost:3000/api/telegram/test || true"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.20.6",
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
