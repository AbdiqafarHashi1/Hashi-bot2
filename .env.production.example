# --- Platform ---
NODE_ENV=production
APP_DOMAIN=
DASHBOARD_PASSWORD=

# --- Infrastructure ---
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/hashi_bot2
REDIS_URL=redis://redis:6379

# --- Runtime lock ---
CAPITAL_MODE=signal
ENGINE_PHASE_LOCK=engine1_only
ENGINE_MODE=live
EXECUTION_MODE=signal_only

# --- Symbols / dispatch ---
DEFAULT_SYMBOLS=ETHUSDT,BTCUSDT
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Crypto market data ---
MARKET_DATA_PRIMARY=binance_futures_ws
MARKET_DATA_FALLBACKS=binance_futures_rest,binance_spot_rest
MARKET_DATA_TIMEFRAME=15m
MARKET_DATA_REST_POLL_MS=12000

# --- Forex market data (disabled by default) ---
FOREX_MARKET_DATA_PRIMARY=
FOREX_MARKET_DATA_API_KEY=
SIGNAL_ENABLE_FOREX=0

# --- Live safety ---
LIVE_SAFETY_ENABLED=true
KILL_SWITCH_MODE=on

# --- Optional hardening defaults ---
SIGNAL_ENABLE_CRYPTO=1
SIGNAL_FOREX_READINESS_ONLY=1
ENABLE_SIGNAL_MODE_OUTPUT=0
