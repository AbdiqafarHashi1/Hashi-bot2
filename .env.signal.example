# Backup/template only for signal operator settings.
# Not used by docker-compose production deployment.
# If needed, copy selective values into .env.production.
APP_DOMAIN=hashibot.example.com
DASHBOARD_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/hashi_bot2
REDIS_URL=redis://redis:6379
NODE_ENV=production
ENGINE_MODE=live
DATA_SOURCE=live
CAPITAL_MODE=signal
EXECUTION_MODE=signal_only
ENGINE_PHASE_LOCK=multi_a_plus
SIGNAL_MIN_TIER=A+
SIGNAL_ALLOW_A=false
SIGNAL_ALLOW_B=false
SIGNAL_SEND_ENTRY=true
SIGNAL_SEND_RESULT=true
ENABLE_SIGNAL_MODE_OUTPUT=true
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
SIGNAL_ENABLE_CRYPTO=1
SIGNAL_ENABLE_FOREX=1
SIGNAL_FOREX_READINESS_ONLY=1
LIVE_SAFETY_ENABLED=true
KILL_SWITCH_MODE=on
