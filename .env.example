# hashi-bot2 environment contract (canonical example)
# Copy to .env at repository root and adjust for your runtime.
#
# Tag legend used in comments:
# - REQUIRED_RUNTIME
# - OPTIONAL_RUNTIME_WITH_DEFAULT
# - OPTIONAL_FEATURE_FLAG
# - EXECUTION_MODE_SPECIFIC / SIGNAL_ONLY / PERSONAL_ONLY / PROP_ONLY
# - FOREX_ONLY / CRYPTO_ONLY
# - LOCAL_DEV_ONLY / DOCKER_ONLY
# - LEGACY_UNUSED

# ===================================================================
# INFRASTRUCTURE / PROCESS BASICS
# ===================================================================
# REQUIRED_RUNTIME (local dev value; docker-compose overrides hostnames to postgres/redis)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hashi_bot2
REDIS_URL=redis://localhost:6379

# OPTIONAL_RUNTIME_WITH_DEFAULT
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=hashi-bot2

# OPTIONAL_FEATURE_FLAG (LOCAL_DEV_ONLY)
# 1 skips worker DB/Redis connectivity checks; runtime loop still starts.
SKIP_INFRA_CHECKS=0

# ===================================================================
# EXECUTION MODE / STRATEGY SWITCHES
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT
EXECUTION_MODE=signal_only
BREAKOUT_ENTRY_MODE=signal
BREAKOUT_OPERATING_MODE=stable
BREAKOUT_EDGE_PROFILE=reinforced
ACTIVE_PRODUCTION_STRATEGY=compression_breakout_balanced
WORKER_LOOP_INTERVAL_SECONDS=15
ENABLE_SWING_RESEARCH_MODE=0

# ===================================================================
# MARKET UNIVERSE / PROVIDERS / TIMEFRAMES
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT
MARKET_TYPE=crypto
DEFAULT_SYMBOL=ETHUSDT
DEFAULT_SYMBOLS=ETHUSDT,BTCUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,MATICUSDT
DEFAULT_CRYPTO_SYMBOLS=ETHUSDT,BTCUSDT,SOLUSDT
DEFAULT_FOREX_SYMBOLS=EURUSD,GBPUSD
DEFAULT_EXECUTION_TIMEFRAME=15m
DEFAULT_HTF_1=1h
DEFAULT_HTF_2=4h
DEFAULT_PRIMARY_PROVIDER=binance
DEFAULT_BACKUP_PROVIDER=bybit
DEFAULT_DATASET_PATH=data/ETHUSDT_15m.csv

# ===================================================================
# SIGNAL MODE QUALITY / FILTERS (SIGNAL_ONLY)
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT
SIGNAL_MIN_TIER=A+
MAX_SIGNALS_PER_CYCLE=3
SIGNAL_OUTCOME_MAX_AGE_SECONDS=21600
SIGNAL_MIN_TP2_R=1.8
SIGNAL_MAX_ENTRY_STRETCH_ATR=0.4
SIGNAL_SYMBOL_COOLDOWN_MINUTES=90
SIGNAL_PARTIAL_AT_TP1_ENABLED=1
SIGNAL_PARTIAL_PCT=0.5
SIGNAL_TP1_PROTECT_MODE=break_even
SIGNAL_TP1_PROTECT_OFFSET_R=0
SIGNAL_BREAKEVEN_BUFFER_R=0
SIGNAL_RESTART_POLICY=resume_persisted
SIGNAL_RESET_CLEAR_RECENT_SIGNALS=0
SIGNAL_RESET_CLEAR_RUNTIME_EVENTS=1
SIGNAL_PAPER_EQUITY=10000
SIGNAL_PAPER_RISK_PCT=0.01
SIGNAL_PAPER_LEVERAGE=1
SIGNAL_PAPER_MAX_TOTAL_NOTIONAL_MULT=1
SIGNAL_PAPER_MAX_OPEN_RISK_PCT=0.05
SIGNAL_PAPER_MAX_CONCURRENT_POSITIONS=10

# ===================================================================
# ALLOCATOR / GOVERNANCE / RISK CAPS
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT
EQUITY_START=10000
PORTFOLIO_PER_SYMBOL_RISK_CAP_PERSONAL_PCT=0.75
PORTFOLIO_PER_SYMBOL_RISK_CAP_PROP_PCT=0.4
GLOBAL_KILL_SWITCH_ENABLED=0
GOVERNANCE_DAILY_LOSS_LOCK_ACTIVE=0
GOVERNANCE_TRAILING_DRAWDOWN_LOCK_ACTIVE=0
GOVERNANCE_MAX_CONSECUTIVE_LOSS_LOCK_ACTIVE=0

# OPTIONAL_FEATURE_FLAG (PERSONAL_ONLY in backtest path)
PERSONAL_THROUGHPUT_EXPANSION=0

# ===================================================================
# EXECUTION REALISM (BACKTEST / VALIDATION)
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT
EXEC_REALISM_ENABLED=0
TAKER_FEE_RATE=0.0006
SLIPPAGE_PCT=0
EXEC_DELAY_MODE=none

# ===================================================================
# SIGNAL OUTPUT / TELEGRAM (SIGNAL_ONLY)
# ===================================================================
# OPTIONAL_FEATURE_FLAG / OPTIONAL_RUNTIME_WITH_DEFAULT
ENABLE_SIGNAL_MODE_OUTPUT=1
TELEGRAM_BOT_TOKEN=__SET_LATER__
TELEGRAM_CHAT_ID=__SET_LATER__
TELEGRAM_PARSE_MODE=Markdown

# ===================================================================
# PERSONAL MODE CONNECTOR (CRYPTO_ONLY / EXECUTION_MODE_SPECIFIC)
# ===================================================================
# OPTIONAL_FEATURE_FLAG
ENABLE_PERSONAL_DEMO_CONNECTOR=1

# OPTIONAL_RUNTIME_WITH_DEFAULT / secrets
BINANCE_DEMO_API_KEY=__SET_LATER__
BINANCE_DEMO_API_SECRET=__SET_LATER__
BINANCE_DEMO_BASE_URL=https://testnet.binancefuture.com
BINANCE_DEMO_SYMBOL_MAP_JSON={"BTCUSDT":"BTCUSDT","ETHUSDT":"ETHUSDT"}

# ===================================================================
# PROP MODE CONNECTOR (FOREX_ONLY / EXECUTION_MODE_SPECIFIC)
# ===================================================================
# OPTIONAL_FEATURE_FLAG
ENABLE_PROP_DEMO_CONNECTOR=1

# OPTIONAL_RUNTIME_WITH_DEFAULT / secrets
MT5_DEMO_LOGIN=__SET_LATER__
MT5_DEMO_PASSWORD=__SET_LATER__
MT5_DEMO_SERVER=__SET_LATER__
MT5_DEMO_BROKER=__SET_LATER__
MT5_DEMO_TERMINAL_ID=__SET_LATER__
MT5_DEMO_SYMBOL_MAP_JSON={"EURUSD":"EURUSD.a","GBPUSD":"GBPUSD.a"}
MT5_BRIDGE_BASE_URL=http://localhost:8080
MT5_BRIDGE_API_KEY=__SET_LATER__

# ===================================================================
# SCRIPT / HARNESS OVERRIDES (LOCAL_DEV_ONLY)
# ===================================================================
# OPTIONAL_RUNTIME_WITH_DEFAULT / OPTIONAL_LOCAL_OVERRIDES
CAPITAL_POLICY_ID=
MULTI_SYMBOL_DATASETS_JSON={}
EDGE_VALIDATION_DATASET=
EXEC_REALISM_DATASET=

# ===================================================================
# LEGACY / CURRENTLY DECLARED BUT NOT CONSUMED DOWNSTREAM
# ===================================================================
# LEGACY_UNUSED (kept for compatibility with existing parser contract)
RISK_MODE=balanced
BASE_RISK_PCT=0.01
MAX_RISK_PCT_CAP=0.025
SIZE_MOD_MIN=0.7
SIZE_MOD_MAX=1.2
MAX_POSITION_NOTIONAL=

# ===================================================================
# DOCKER NOTES (DOCKER_ONLY)
# ===================================================================
# docker-compose service-level values (not read by app code directly):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=hashi_bot2
# Container runtime overrides app DATABASE_URL/REDIS_URL hostnames to:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hashi_bot2
# REDIS_URL=redis://redis:6379
