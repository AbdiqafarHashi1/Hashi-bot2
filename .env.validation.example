# Validation environment template used by local validation scripts.
# Safe default: mirrors production signal-only safety posture.
APP_DOMAIN=validation.local
DASHBOARD_PASSWORD=validation_pass
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hashi_bot2
REDIS_URL=redis://localhost:6379
NODE_ENV=production
ENGINE_MODE=live
DATA_SOURCE=live
CAPITAL_MODE=signal
EXECUTION_MODE=signal_only
ENGINE_PHASE_LOCK=multi_a_plus
SIGNAL_MIN_TIER=A+
SIGNAL_ALLOW_A=false
SIGNAL_ALLOW_B=false
SIGNAL_SEND_ENTRY=true
SIGNAL_SEND_RESULT=true
ENABLE_SIGNAL_MODE_OUTPUT=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SIGNAL_ENABLE_CRYPTO=1
SIGNAL_ENABLE_FOREX=1
SIGNAL_FOREX_READINESS_ONLY=1
LIVE_SAFETY_ENABLED=true
KILL_SWITCH_MODE=on
